class Solution(object):
    def isNumber(self, s):
        """
        :type s: str
        :rtype: bool
        """
        seen_digit = seen_exponent = seen_dot = False
        
        for i, char in enumerate(s):
            if char.isdigit():
                seen_digit = True
            elif char in ["+", "-"]:
                # Signs can only be at index 0 or immediately after 'e'/'E'
                if i > 0 and s[i-1].lower() != 'e':
                    return False
            elif char.lower() == "e":
                # Exponent needs to follow a digit and be the only exponent
                if seen_exponent or not seen_digit:
                    return False
                seen_exponent = True
                seen_digit = False # Reset digit flag to ensure digits follow 'e'
            elif char == ".":
                # Dot cannot appear after an exponent or twice
                if seen_dot or seen_exponent:
                    return False
                seen_dot = True
            else:
                # Any other character (like letters) is invalid
                return False
                
        return seen_digit

class Solution(object):
    def reverseKGroup(self, head, k):
        # 1. Check if there are at least k nodes left to reverse
        curr = head
        for _ in range(k):
            if not curr:
                return head  # Less than k nodes, return head as is
            curr = curr.next
        
        # 2. Reverse the first k nodes
        prev = None
        curr = head
        for _ in range(k):
            nxt = curr.next
            curr.next = prev
            prev = curr
            curr = nxt
            
        # 3. 'head' is now the tail of the reversed group.
        # Recursively call for the next group and connect it.
        head.next = self.reverseKGroup(curr, k)
        
        # 4. 'prev' is the new head of this reversed k-group
        return prev

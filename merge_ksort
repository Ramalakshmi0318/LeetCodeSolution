import heapq

class Solution(object):
    def mergeKLists(self, lists):
        # Use a min-heap to keep track of the smallest node among the k lists
        min_heap = []
        
        # Initialise the heap with the head of each non-empty list
        for i, l in enumerate(lists):
            if l:
                # Store (value, index, node) to handle tie-breakers for nodes with same value
                heapq.heappush(min_heap, (l.val, i, l))
        
        dummy = ListNode(0)
        current = dummy
        
        while min_heap:
            val, i, node = heapq.heappop(min_heap)
            current.next = node
            current = current.next
            
            # If the extracted node has a next node, push it into the heap
            if node.next:
                heapq.heappush(min_heap, (node.next.val, i, node.next))
                
        return dummy.next

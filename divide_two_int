class Solution(object):
    def divide(self, dividend, divisor):
        MAX_INT = 2147483647
        MIN_INT = -2147483648
        # Handle overflow
        if dividend == MIN_INT and divisor == -1: return MAX_INT
        
        is_positive = (dividend > 0) == (divisor > 0)
        a, b = abs(dividend), abs(divisor)
        res = 0
        
        # Bit manipulation to subtract largest multiples of divisor
        while a >= b:
            temp_divisor, multiple = b, 1
            while a >= (temp_divisor << 1):
                temp_divisor <<= 1
                multiple <<= 1
            a -= temp_divisor
            res += multiple
            
        return res if is_positive else -res

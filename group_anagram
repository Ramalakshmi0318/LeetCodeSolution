from collections import defaultdict

class Solution(object):
    def groupAnagrams(self, strs):
        """
        :type strs: List[str]
        :rtype: List[List[str]]
        """
        # Map character counts to a list of strings
        ans = defaultdict(list)
        
        for s in strs:
            # Create a count of 26 letters (a-z)
            count = [0] * 26
            for c in s:
                count[ord(c) - ord('a')] += 1
            
            # Use the count tuple as a key (tuples are hashable, lists are not)
            ans[tuple(count)].append(s)
            
        return list(ans.values())

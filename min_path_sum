class Solution(object):
    def minPathSum(self, grid):
        """
        :type grid: List[List[int]]
        :rtype: int
        """
        rows, cols = len(grid), len(grid[0])
        
        # We can reuse the first row of the grid as our DP array
        # to achieve O(n) space complexity.
        dp = [float('inf')] * cols
        dp[0] = 0 # Base case: starting point has no "previous" cost
        
        for r in range(rows):
            for c in range(cols):
                if c == 0:
                    # For the first column, you can only come from above
                    dp[c] += grid[r][c]
                else:
                    # Minimum of coming from above (dp[c]) or from the left (dp[c-1])
                    dp[c] = min(dp[c], dp[c-1]) + grid[r][c]
                    
        return dp[-1]

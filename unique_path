class Solution(object):
    def uniquePaths(self, m, n):
        """
        :type m: int
        :type n: int
        :rtype: int
        """
        # Initialize a single row with 1s (representing the top row)
        row = [1] * n
        
        # Iterate through the grid row by row (starting from the second row)
        for i in range(m - 1):
            new_row = [1] * n
            # Start from index 1 because the first column is always 1
            for j in range(1, n):
                # Ways to reach current = ways from above (row[j]) + ways from left (new_row[j-1])
                new_row[j] = new_row[j-1] + row[j]
            row = new_row
            
        return row[-1]

class Solution(object):
    def solveSudoku(self, board):
        # Tracking sets for fast O(1) lookups
        rows = [set() for _ in range(9)]
        cols = [set() for _ in range(9)]
        boxes = [set() for _ in range(9)]
        empty_cells = []

        # Initialize sets with existing numbers and find empty cells
        for r in range(9):
            for c in range(9):
                char = board[r][c]
                if char != '.':
                    rows[r].add(char)
                    cols[c].add(char)
                    boxes[(r // 3) * 3 + (c // 3)].add(char)
                else:
                    empty_cells.append((r, c))

        def backtrack(index):
            if index == len(empty_cells):
                return True
            
            r, c = empty_cells[index]
            box_idx = (r // 3) * 3 + (c // 3)

            for char in "123456789":
                # Instant lookup instead of looping through the board
                if char not in rows[r] and char not in cols[c] and char not in boxes[box_idx]:
                    # Place number
                    board[r][c] = char
                    rows[r].add(char)
                    cols[c].add(char)
                    boxes[box_idx].add(char)

                    if backtrack(index + 1):
                        return True

                    # Backtrack (remove)
                    board[r][c] = '.'
                    rows[r].remove(char)
                    cols[c].remove(char)
                    boxes[box_idx].remove(char)
            
            return False

        backtrack(0)

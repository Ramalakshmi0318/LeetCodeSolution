class Solution(object):
    def totalNQueens(self, n):
        """
        :type n: int
        :rtype: int
        """
        self.count = 0
        cols = set()
        pos_diag = set()  # (r + c)
        neg_diag = set()  # (r - c)

        def backtrack(r):
            if r == n:
                self.count += 1
                return

            for c in range(n):
                # Check for conflicts
                if c in cols or (r + c) in pos_diag or (r - c) in neg_diag:
                    continue

                # Place queen
                cols.add(c)
                pos_diag.add(r + c)
                neg_diag.add(r - c)

                # Move to next row
                backtrack(r + 1)

                # Backtrack: remove queen
                cols.remove(c)
                pos_diag.remove(r + c)
                neg_diag.remove(r - c)

        backtrack(0)
        return self.count
